# ============================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================
# Reemplaza estos valores con tus credenciales reales

DATABASE_URL=jdbc:postgresql://aws-1-us-west-2.pooler.supabase.com:5432/postgres
DATABASE_USERNAME=postgres.bmclwyckvsywscextvxo
DATABASE_PASSWORD=Neiva$Solidaria2026

# ============================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ============================================
# Puerto en el que ejecutará la aplicación (por defecto 8080)
SERVER_PORT=8080

# Perfil de Spring (dev, test, prod)
SPRING_PROFILE=dev

# ============================================
# CONFIGURACIÓN DE LOGGING
# ============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE_HACKATHON=DEBUG

# ============================================
# CONFIGURACIÓN DE SEGURIDAD
# ============================================
# Secreto para JWT (si lo implementas)
JWT_SECRET=your_jwt_secret_key_here

# Token de sesión
JWT_EXPIRATION=86400000

# ============================================
# CONFIGURACIÓN DE CORREO (Opcional)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password

# ============================================
# CONFIGURACIÓN DE STORAGE (Opcional)
# ============================================
AWS_ACCESS_KEY=your_aws_key
AWS_SECRET_KEY=your_aws_secret
AWS_REGION=us-west-2
AWS_S3_BUCKET=neivasolidaria

